# ─── Secrets / environment ──────────────────────────────────────────────
# NEVER commit real env files. Use .env.example as the template.
.env
.env.local
.env.*.local
**/.env
!**/.env.example
!.env.example

# ─── Dependencies ───────────────────────────────────────────────────────
node_modules/
**/node_modules/
.pnp
.pnp.*

# ─── Build output ───────────────────────────────────────────────────────
dist/
**/dist/
build/
**/build/
.next/
**/.next/
out/
**/out/
*.tsbuildinfo
**/*.tsbuildinfo

# ─── Prisma generated client ────────────────────────────────────────────
**/.prisma/
**/generated/

# ─── Runtime / caches ───────────────────────────────────────────────────
# Finance disk cache
.cache/
**/.cache/
# PM2
.pm2/
# Logs
.logs/
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Tooling / editor ───────────────────────────────────────────────────
.DS_Store
*.pem
.vscode/
.idea/
graphify-out/

# ─── Temp ───────────────────────────────────────────────────────────────
*.tmp
*.tmp[0-9]*
