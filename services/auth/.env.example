# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/uzum_dashboard?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# SMS (Twilio or Essek)
SMS_PROVIDER=twilio
SMS_TWILIO_ACCOUNT_SID=your_account_sid
SMS_TWILIO_AUTH_TOKEN=your_auth_token
SMS_TWILIO_PHONE_NUMBER=+1234567890

# App
APP_NAME=Uzum Auth Service
APP_PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# Telegram Bot (BotFather'dan olingan token)
TELEGRAM_BOT_TOKEN=
# Bot username (without @)
TELEGRAM_BOT_USERNAME=
# Admin chat ID — bot ishga tushganida shu chatga xabar yuboradi
TELEGRAM_ADMIN_ID=