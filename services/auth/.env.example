# ─── Database ────────────────────────────────────────────────────────────
# Production: use a STRONG password (24+ random chars), not a default.
DATABASE_URL="postgresql://uzum:CHANGE_ME_STRONG_DB_PASSWORD@localhost:5432/uzum_dashboard?schema=public"

# ─── Redis ───────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# Production: ALWAYS set a Redis password.
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_DB=0

# ─── JWT ─────────────────────────────────────────────────────────────────
# Generate each with: openssl rand -hex 48   (or: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))")
# MUST be different from each other. NEVER reuse across environments.
JWT_SECRET=CHANGE_ME_run_openssl_rand_hex_48
JWT_REFRESH_SECRET=CHANGE_ME_run_openssl_rand_hex_48_DIFFERENT
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# ─── Encryption (AES-256 for stored Uzum API keys) ───────────────────────
# MUST be exactly 32 characters. Generate: node -e "console.log(require('crypto').randomBytes(24).toString('base64').replace(/[^a-zA-Z0-9]/g,'').slice(0,32))"
# WARNING: changing this on a DB with existing stores makes their saved API keys
# undecryptable — they must re-enter their Uzum API key (or run a re-encrypt migration).
ENCRYPTION_SECRET=CHANGE_ME_exactly_32_characters_

# ─── SMS provider: console | eskiz | twilio ──────────────────────────────
# Production MUST use a real provider (eskiz for Uzbekistan). "console" only prints
# the OTP to the server log — never use it in production.
SMS_PROVIDER=eskiz
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
SMS_TWILIO_ACCOUNT_SID=
SMS_TWILIO_AUTH_TOKEN=
SMS_TWILIO_PHONE_NUMBER=

# ─── App ─────────────────────────────────────────────────────────────────
APP_NAME=Uzum Auth Service
APP_PORT=3001
NODE_ENV=production
# Comma-separated allowed origins. Production: your real frontend domain(s) only.
CORS_ORIGINS=https://yourdomain.com

# ─── Telegram Bot (token from @BotFather) ────────────────────────────────
TELEGRAM_BOT_TOKEN=
# Bot username (without @)
TELEGRAM_BOT_USERNAME=
# Admin chat ID — bot sends a startup notice here
TELEGRAM_ADMIN_ID=
