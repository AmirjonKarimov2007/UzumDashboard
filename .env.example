# Database
POSTGRES_USER=uzum
POSTGRES_PASSWORD=change_me_strong_password_32chars
POSTGRES_DB=uzum_dashboard
DATABASE_URL=postgresql://uzum:change_me_strong_password_32chars@localhost:5432/uzum_dashboard

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password
REDIS_DB=0

# JWT — generate with: openssl rand -hex 64
JWT_SECRET=change_me_jwt_secret_minimum_64_characters_long_for_security
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret_different_from_jwt_secret_64chars
JWT_REFRESH_EXPIRES_IN=7d

# Encryption — MUST be exactly 32 characters for AES-256
ENCRYPTION_SECRET=change_me_32_char_encryption_key!

# CORS
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# SMS Provider (mock for dev, actual for prod)
SMS_PROVIDER=mock
SMS_API_KEY=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
