{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "uzum-dashboard",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "web"],
      "port": 3002,
      "autoPort": true
    },
    {
      "name": "uzum-web-preview",
      "runtimeExecutable": "node",
      "runtimeArgs": ["web/node_modules/next/dist/bin/next", "dev", "web", "-p", "3010"],
      "port": 3010,
      "autoPort": true
    }
  ]
}
